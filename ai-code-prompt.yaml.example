source: [
  "."
]

exclude_patterns: [
  ".git*",
  "logs/",
  "lib/__pycache__/",
  "__pycache__/",
  "*.log",
  "*.bat"
]

tree_dirs: [
]

prompt: |
  Remove all the docker configuration and usage, discard the cache configs. I don't want to use at all docker for now.

  Use simply local file storage for user files. Store each user file in its user id sub-folder.

  Use just a local database with sqlite3.

system: |
  You are a senior programming developer assistant. Analyze the following project files and help the user with described issues by rewriting, modifying, deleting, refactoring the code.

  You are responsible for preparing the production website for public launch. Treat this as a mission-critical deployment: the website must be fully functional across both frontend and backend, rigorously secure, easily scalable, and robustly engineered for ongoing public usage. As you work, think methodically and comprehensively through every stage of implementation and do not overlook any implicit or supporting technical steps crucial to production readiness, even if not explicitly described in initial objectives.

  For all code and configuration, provide deeply informative comments that clarify your logic, document all decisions, and support future maintenance or handovers. As you develop solutions, meticulously break down each objective into the smallest possible technical actions and address them one at a time, only proceeding once each is thorough and sound.

  Implement all work following industry best practices for security, scalability, reliability, and long-term support. Proactively include essential techniques such as input validation, error management, logging, and operational monitoring. Consider compliance and data protection throughout.

  For each decision and implementation step, provide full explanations and rationale, using clear code comments for technical documentation. Ensure that the delivered solution is exhaustive, production-grade, maintainable, and anticipates all reasonable future needs—especially. Do not provide summaries, layout, or graphic elements; concentrate on precise, actionable development and documentation only.

  Be aggressive with code changes: remove code blocks, refactor the code, don't be afraid to rewrite conceptually the code. Make improvements by adding, removing or improving code blocks.


ANTHROPIC:
  API_KEY: sk-ant-api03-EXAMPLE-hEqqwgAA
  # key name: 

  MAX_TOKENS: 32000
  MAX_TOKENS_THINK: 5000

  CLAUDE_MODEL: claude-opus-4-20250514
  # claude-sonnet-4-20250514
  # claude-opus-4-20250514

# When true, Claude may use SEARCH/REPLACE PATCH blocks for small, targeted
# edits instead of rewriting entire files.  When false, the PATCH instruction
# is omitted from the system prompt and any PATCH blocks in responses are
# treated as full-file EDITs (the content is written as-is).
PATCH_ENABLED: true

# Play an audible bell sound when -ai, -ai-steps, or -gen-source workflows
# finish completely. Works on both Windows and macOS.
SOUND_ENABLED: true

# Web search configuration:
# WEBSEARCH: master toggle to enable/disable automatic web searches that will be
# included in the message_content sent to Claude (DuckDuckGo).
WEBSEARCH: false
WEBSEARCH_MAX_RESULTS: 5

# Memory system: provides Claude with persistent context across invocations.
# Long-term memory is stored at <project_root>/.ai-code/memory/long-term.md and
# tracked in the master project's git history.
# Short-term memory is stored at <ai-code-dir>/memory/short-term.md for
# ephemeral ai-steps workflow state.
# Git history provides recent commit context.
MEMORY:
  ENABLED: true                    # Master toggle for entire memory system
  LONG_TERM_ENABLED: true          # Toggle long-term project memory (../.ai-code/memory/long-term.md)
  SHORT_TERM_ENABLED: true         # Toggle short-term ai-steps memory (./memory/short-term.md)
  GIT_HISTORY_ENABLED: true        # Toggle git history context (last N commits)
  GIT_HISTORY_COMMITS: 30          # Number of recent commits to include
  LONG_TERM_MAX_TOKENS: 2000      # Soft cap: triggers compaction when exceeded
  SHORT_TERM_MAX_TOKENS: 1000     # Soft cap for short-term memory
  AUTO_UPDATE: true                # Auto-update project memory after each execution
